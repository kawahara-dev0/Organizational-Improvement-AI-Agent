# ── Database (local Docker) ──────────────────────────────────────────────────
POSTGRES_DB=oiagent
POSTGRES_USER=oiagent
POSTGRES_PASSWORD=oiagent

# ── Supabase (production / cloud) ────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── AI Models ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Feature flags ────────────────────────────────────────────────────────────
# Set to "true" only in production to enable Claude routing
ENABLE_CLAUDE_ROUTING=false

# ── Free-tier API usage controls ─────────────────────────────────────────────
# Set RAG_ENABLED=false to skip vector search (saves 1 embed API call per turn)
RAG_ENABLED=true
# Run metadata extraction every N assistant turns (0 = disabled)
METADATA_EXTRACTION_INTERVAL=3

# ── Admin auth ───────────────────────────────────────────────────────────────
# [PRODUCTION] Change to a strong, unique password — NEVER leave as "changeme"
ADMIN_PASSWORD=changeme
# [PRODUCTION] Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# NEVER leave as the default value in production.
JWT_SECRET=changeme-jwt-secret-replace-in-production

# ── Privacy / security ────────────────────────────────────────────────────────
# Fernet key for encrypting consultation messages at rest.
# [PRODUCTION] Generate once and keep secret:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to store messages unencrypted (development default).
MESSAGES_ENCRYPTION_KEY=

# Auto-delete non-submitted (abandoned) consultation sessions after N days.
# Submitted proposals are retained regardless of this setting.
# Set to 0 to disable automatic deletion.
CONSULTATION_RETENTION_DAYS=0

# ── CORS ─────────────────────────────────────────────────────────────────────
# Space-separated list of allowed origins for the API.
# [PRODUCTION] Set to the exact URL(s) of your frontend (no trailing slash).
# Example: CORS_ORIGINS=https://your-app.example.com
CORS_ORIGINS=http://localhost:3000

# ── Rate limiting ─────────────────────────────────────────────────────────────
# slowapi format: "N/period" where period is second/minute/hour/day
# Controls how many chat requests each client IP may make per minute.
CHAT_RATE_LIMIT=30/minute

# ── App ──────────────────────────────────────────────────────────────────────
# Set to "production" in production — triggers secrets validation at startup.
APP_ENV=development
LOG_LEVEL=INFO

# ── Next.js ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Database (local Docker) ──────────────────────────────────────────────────
POSTGRES_DB=oiagent
POSTGRES_USER=oiagent
POSTGRES_PASSWORD=oiagent

# ── Supabase (production / cloud) ────────────────────────────────────────────
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── AI Models ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# ── Feature flags ────────────────────────────────────────────────────────────
# Set to "true" only in production to enable Claude routing
ENABLE_CLAUDE_ROUTING=false

# ── Free-tier API usage controls ─────────────────────────────────────────────
# Set RAG_ENABLED=false to skip vector search (saves 1 embed API call per turn)
RAG_ENABLED=true
# Run metadata extraction every N assistant turns (0 = disabled)
METADATA_EXTRACTION_INTERVAL=3

# ── Admin auth ───────────────────────────────────────────────────────────────
# Password for the /admin/login endpoint (change in production)
ADMIN_PASSWORD=changeme
# Secret used to sign JWT tokens (use a long random string in production)
JWT_SECRET=changeme-jwt-secret-replace-in-production

# ── Privacy / security ────────────────────────────────────────────────────────
# Fernet key for encrypting consultation messages at rest.
# Generate once and keep secret:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to store messages unencrypted (development default).
MESSAGES_ENCRYPTION_KEY=

# Auto-delete non-submitted (abandoned) consultation sessions after N days.
# Submitted proposals are retained regardless of this setting.
# Set to 0 to disable automatic deletion.
CONSULTATION_RETENTION_DAYS=0

# ── Next.js ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
